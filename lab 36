import numpy as np

feature = np.array([30.0,50.0,10.0])
weights = np.array([0.05,0.8,-0.1])

a = feature + weights

b = 0.1 * feature

c = np.linalg.norm(feature)
d = np.linalg.norm(weights)

print("feature shape:", feature.shape)
print("weights shape:", weights.shape)

print("add:", a)
print("scaled:", b)

print("feature norm:", c)
print("weights norm:", d)
