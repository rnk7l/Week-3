import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt

a = 10000

b = np.random.uniform(0,1,a)
c = np.random.normal(0,1,a)

sns.histplot(b, kde=True)
plt.show()

sns.histplot(c, kde=True)
plt.show()

print("uniform mean:", np.mean(b))
print("uniform std:", np.std(b))

print("normal mean:", np.mean(c))
print("normal std:", np.std(c))
